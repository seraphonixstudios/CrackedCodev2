{
  "name": "CrackedCode",
  "version": "2.6.0",
  "description": "Autonomous AI Coding Agent with Multi-Agent Swarm, Voice I/O, and Production-Ready App Generation",
  "model": "qwen3:8b-gpu",
  "vision_model": "llava:13b-gpu",
  "secondary_model": "dolphin-llama3:8b-gpu",
  "unified_mode": false,
  "autonomous_enabled": true,
  "autonomous_max_corrections": 3,
  "autonomous_workspace": ".autonomous",
  "streaming_enabled": true,
  "cache_enabled": true,
  "max_context": 20,
  "max_retries": 2,
  "whisper_size": "medium.en",
  "tts_voice": "en_US-lessac-medium",
  "sample_rate": 16000,
  "push_to_talk": false,
  "max_concurrent_agents": 4,
  "task_timeout": 120,
  "ollama_host": "http://localhost:11434",
  "allowed_shell_commands": [
    "git",
    "npm",
    "node",
    "python",
    "python3",
    "pip",
    "pip3",
    "ruff",
    "mypy",
    "pytest",
    "cargo",
    "go",
    "curl",
    "wget",
    "ls",
    "dir",
    "cd",
    "mkdir",
    "rm",
    "cat",
    "type",
    "find",
    "grep",
    "rg",
    "echo"
  ],
  "project_root": ".",
  "log_level": "INFO",
  "voice_enabled": true,
  "auto_save_blackboard": true,
  "debate_rounds": 3,
  "max_retries": 2,
  "temperature": 0.1,
  "num_ctx": 16384,
  "agents": {
    "supervisor": {
      "enabled": true,
      "system_prompt": "You are the Supervisor Agent - the orchestrator of the CrackedCode Multi-Agent Swarm."
    },
    "architect": {
      "enabled": true,
      "system_prompt": "You are the Architect Agent - system design specialist."
    },
    "coder": {
      "enabled": true,
      "system_prompt": "You are the Coder Agent - code generation specialist."
    },
    "executor": {
      "enabled": true,
      "system_prompt": "You are the Executor Agent - command execution specialist."
    },
    "reviewer": {
      "enabled": true,
      "system_prompt": "You are the Reviewer Agent - code critique specialist."
    }
  },
  "features": {
    "voice_io": true,
    "multi_agent_swarm": true,
    "debate_protocol": true,
    "blackboard_memory": true,
    "tool_use": true,
    "json_output": true,
    "parallel_execution": true,
    "plan_build_mode": true,
    "autonomous_production": true,
    "heartbeat_scheduler": true,
    "skill_system": true,
    "persistent_workspace": true
  },
  "models": {
    "recommended": [
      "qwen3:8b-gpu",
      "llava:13b-gpu",
      "dolphin-llama3:8b-gpu"
    ],
    "stt": [
      "tiny",
      "base",
      "small",
      "medium"
    ],
    "tts": [
      "en_US-lessac-medium"
    ]
  },
  "security": {
    "allow_arbitrary_code": false,
    "sandbox_commands": true,
    "command_whitelist_only": true
  },
  "performance": {
    "max_workers": 4,
    "task_timeout": 120,
    "gpu_acceleration": true
  }
}